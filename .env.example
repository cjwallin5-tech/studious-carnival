# Copy this file to .env and adjust values for your environment.

# App
PROJECT_NAME="Social Network API"
ENVIRONMENT="local"  # local | staging | production
API_V1_PREFIX="/api/v1"

# Security — CHANGE THIS in any real deployment.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY="changeme-dev-secret-key-do-not-use-in-production"
# 7 days
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database
DATABASE_URL="postgresql+psycopg://user:password@localhost:5432/social_network"
# DATABASE_URL="sqlite:///./social_network.db"

# CORS — comma-separated list of allowed origins.
BACKEND_CORS_ORIGINS="http://localhost:3000,http://localhost:5173"
